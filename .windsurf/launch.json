{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flask Blog - Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "env": {
                "FLASK_APP": "run.py",
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "1"
            },
            "jinja": true,
            "autoStartBrowser": false
        },
        {
            "name": "Flask Blog - Run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "env": {
                "FLASK_APP": "run.py",
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "0"
            },
            "jinja": false,
            "autoStartBrowser": true
        },
        {
            "name": "Flask CLI - Debug",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "python": "${workspaceFolder}/.venv/bin/python",
            "env": {
                "FLASK_APP": "run.py",
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "1"
            },
            "args": [
                "run",
                "--host=0.0.0.0",
                "--port=5000",
                "--debugger",
                "--reload"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "jinja": true,
            "autoStartBrowser": false
        },
        {
            "name": "Flask CLI - Run",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "python": "${workspaceFolder}/.venv/bin/python",
            "env": {
                "FLASK_APP": "run.py",
                "FLASK_ENV": "production",
                "FLASK_DEBUG": "0"
            },
            "args": [
                "run",
                "--host=0.0.0.0",
                "--port=5000"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "jinja": false,
            "autoStartBrowser": true
        }
    ]
}